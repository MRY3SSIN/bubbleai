    "jest-expo": "~54.0.13",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
