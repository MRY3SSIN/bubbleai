{
  "expo": {
    "name": "BubbleAI",
    "slug": "bubbleai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bubbleai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7fbf8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bubbleai.mobile",
      "infoPlist": {
        "NSContactsUsageDescription": "BubbleAI uses your selected contacts for trusted support and clinician details.",
        "NSUserNotificationsUsageDescription": "BubbleAI uses notifications for check-ins, journaling, sleep, and gentle wellness reminders.",
        "NSMicrophoneUsageDescription": "BubbleAI uses your microphone for voice journaling and live voice support.",
        "NSPhotoLibraryUsageDescription": "BubbleAI lets you choose a profile photo that feels personal and calm.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bubbleai.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f7fbf8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "BubbleAI lets you choose a profile photo that feels personal and calm."
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#12a28b",
          "defaultChannel": "bubbleai-reminders",
          "sounds": []
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9808ea83-f87b-4b52-89c6-4ea58dbc07f4"
      },
      "router": {}
    },
    "owner": "yassineouni"
  }
}
